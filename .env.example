# Backend application
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000
SENTRY_DSN=

# LLM generation via LiteLLM
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini/gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=8192
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120.0

# Embeddings
EMBEDDING_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=gemini/text-embedding-004

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_DB_URL=postgresql+psycopg://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PAPERS_BUCKET=papers
SUPABASE_OUTPUTS_BUCKET=outputs

# Langfuse observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Pipeline behavior
PIPELINE_CACHE_ENABLED=true
PIPELINE_MAX_PAGES=60
PIPELINE_TOKEN_BUDGET_PER_PAPER=500000
# PIPELINE_ENABLED_STAGES=ingest,classify,extract

# Frontend convenience values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_API_URL=http://localhost:8000
