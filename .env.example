# ── App ─────────────────────────────────────────────────────────────────────
APP__ENVIRONMENT=development          # development | staging | production
APP__DEBUG=false
APP__LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini/gemini-2.0-flash
GEMINI_VISION_MODEL=gemini/gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini/text-embedding-004
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_SECONDS=120.0

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_DB_URL="postgresql+psycopg://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres"
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PAPERS_BUCKET=papers
SUPABASE_OUTPUTS_BUCKET=outputs

# ── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_CACHE_ENABLED=true
PIPELINE_MAX_PAGES=60
PIPELINE_TOKEN_BUDGET_PER_PAPER=500000
# PIPELINE_ENABLED_STAGES=ingest,classify,extract   # leave empty to run all

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=generate_a_random_secret_here
